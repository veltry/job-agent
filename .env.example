# ─────────────────────────────────────────────────────────────────
# Job Agent v2.0 - Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to GitHub!
# ─────────────────────────────────────────────────────────────────

# ── Telegram (from @BotFather and @userinfobot) ──────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_USER_ID=123456789

# ── Google Gemini (from aistudio.google.com) ─────────────────────
GEMINI_API_KEY=AIzaSy_your_key_here

# ── Agent Behaviour (optional - defaults shown) ────────────────────
MATCH_THRESHOLD=70
SCAN_INTERVAL_HOURS=4
MAX_JOBS_PER_SCAN=50
RATE_LIMIT_SECONDS=4

# ── Job Sources (optional) ────────────────────────────────────────

# LinkedIn via Apify (optional - for LinkedIn job scraping)
# Get key: https://console.apify.com/sign-up
# Free tier: ~100 results/month
APIFY_API_KEY=
APIFY_ACTOR_ID=BHzefUZlZRKWxkTck

# Jooble (optional - good for Asia jobs)
# Get key: https://www.jooble.org/api
# Free tier available
JOOBLE_API_KEY=

# ── Email (Gmail SMTP) ───────────────────────────────────────────
# For sending cover letters with resume attachment
# Enable 2FA and get App Password: https://myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
FROM_EMAIL=your_email@gmail.com
